# Dockerfile for building and running ODBC tests against the old driver
FROM rockylinux:9

ENV CARGO_HOME=/root/.cargo
ENV RUSTUP_HOME=/root/.rustup
ENV PATH="/root/.cargo/bin:${PATH}"

# Install all system packages in one layer
RUN dnf install -y \
        epel-release \
        dnf-plugins-core && \
    (dnf config-manager --set-enabled powertools || dnf config-manager --set-enabled crb) && \
    dnf install -y \
        autoconf \
        automake \
        awscli \
        bash \
        cmake \
        gcc \
        gcc-c++ \
        git \
        gzip \
        libstdc++-devel \
        libstdc++-static \
        libtool \
        python3 \
        tar \
        unixODBC-devel \
        which \
        zlib-devel && \
    ln -s /usr/bin/python3 /usr/bin/python && \
    dnf clean all && \
    rm -rf /var/cache/dnf

# Install Rust
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y

# Install CMake 4.0 (detect architecture automatically)
RUN ARCH=$(uname -m) && \
    cd /tmp && \
    curl -L "https://github.com/Kitware/CMake/releases/download/v4.0.0/cmake-4.0.0-linux-${ARCH}.tar.gz" -o cmake.tar.gz && \
    tar -xzf cmake.tar.gz && \
    mv "cmake-4.0.0-linux-${ARCH}" /opt/cmake-4.0.0 && \
    ln -s /opt/cmake-4.0.0/bin/cmake /usr/bin/cmake4 && \
    ln -s /opt/cmake-4.0.0/bin/ctest /usr/bin/ctest4 && \
    ln -s /opt/cmake-4.0.0/bin/cpack /usr/bin/cpack4 && \
    ln -s /opt/cmake-4.0.0/bin/ccmake /usr/bin/ccmake4 && \
    rm -rf /tmp/cmake*

# Install Snowflake ODBC driver (detect architecture automatically)
# Note: Snowflake repo uses "linux" for x86_64 and "linuxaarch64" for aarch64
ARG REFERENCE_ODBC_VERSION
ARG REFERENCE_ODBC_SHA256
RUN ARCH=$(uname -m) && \
    if [ "$ARCH" = "x86_64" ]; then \
        URL_PATH="linux"; \
    else \
        URL_PATH="linux${ARCH}"; \
    fi && \
    RPM="snowflake-odbc-${REFERENCE_ODBC_VERSION}.${ARCH}.rpm" && \
    cd /tmp && \
    curl -O "https://sfc-repo.snowflakecomputing.com/odbc/${URL_PATH}/${REFERENCE_ODBC_VERSION}/${RPM}" && \
    echo "${REFERENCE_ODBC_SHA256}  ${RPM}" | sha256sum -c - && \
    # --nosignature: Snowflake RPMs are not GPG-signed; integrity is verified
    # by the pinned SHA256 checksum above (see ci/reference-odbc-checksums).
    rpm -i --nosignature "${RPM}" && \
    rm -f snowflake-odbc-*.rpm

RUN git config --global --add safe.directory '*'
